# ====================================================================
# Business OS — Environment Variables (.env.example)
# Copy to .env and fill in real values. NEVER commit .env to git!
# ====================================================================

# === Application ===
ENVIRONMENT=development         # development | staging | production
DEBUG=false
SECRET_KEY=your-super-secret-key-32-chars-min
API_URL=https://api.business-os.ru

# === Telegram ===
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
MINI_APP_URL=https://miniapp.business-os.ru

# === Database ===
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/business_os
DB_PASSWORD=secure-db-password

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1

# === YandexGPT (AI/NLP) ===
YANDEXGPT_FOLDER_ID=b1g...xxx
YANDEXGPT_IAM_TOKEN=t1.9eu...xxx

# === Banks ===
TINKOFF_CLIENT_ID=your-tinkoff-client-id
TINKOFF_CLIENT_SECRET=your-tinkoff-secret
TINKOFF_WEBHOOK_SECRET=your-tinkoff-webhook-secret
SBER_CLIENT_ID=your-sber-client-id
SBER_CLIENT_SECRET=your-sber-secret
SBER_WEBHOOK_SECRET=your-sber-webhook-secret
BANK_TOKEN_ENCRYPTION_KEY=32-byte-encryption-key-here!!
# NOTE: BANK_TOKEN_ENCRYPTION_KEY must be exactly 32 bytes.
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"

# === YooKassa (payments) ===
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=webhook-verification-secret

# === S3 / Selectel Object Storage ===
S3_ENDPOINT=https://s3.selectel.ru
S3_BUCKET=business-os-documents
S3_KEY=your-s3-access-key
S3_SECRET=your-s3-secret-key
S3_REGION=ru-1

# === Monitoring ===
SENTRY_DSN=https://xxx@yyy.sentry.io/zzz
GRAFANA_API_KEY=glsa_...

# === Email (document sending) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@business-os.ru
SMTP_PASSWORD=your-smtp-password
